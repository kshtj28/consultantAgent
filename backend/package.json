{
    "name": "consultant-agent-backend",
    "version": "1.0.1",
    "description": "Backend for Consultant Agent with Mastra AI",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "mastra:dev": "npx mastra dev",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "runIts": "vitest run src/integration-tests",
        "lint": "tsc --noEmit",
        "migrate:readiness": "npx tsx src/scripts/migrateReadinessSessions.ts"
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.25",
        "@ai-sdk/groq": "^3.0.34",
        "@anthropic-ai/sdk": "^0.72.1",
        "@aws-sdk/client-auto-scaling": "^3.0.0",
        "@aws-sdk/client-ecs": "^3.0.0",
        "@google/generative-ai": "^0.24.1",
        "@mastra/core": "^1.1.0",
        "@mastra/opensearch": "^1.0.0",
        "@opensearch-project/opensearch": "^2.5.0",
        "@types/bcryptjs": "^3.0.0",
        "axios": "^1.6.0",
        "bcryptjs": "^3.0.3",
        "body-parser": "^1.20.2",
        "cors": "^2.8.5",
        "csv-parse": "^5.5.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "mammoth": "^1.6.0",
        "multer": "^1.4.5-lts.1",
        "openai": "^4.24.0",
        "pdf-parse": "^1.1.1",
        "uuid": "^9.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-serve-static-core": "^5.1.1",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.0",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^9.0.7",
        "supertest": "^7.2.2",
        "tsx": "^4.6.2",
        "typescript": "^5.3.2",
        "vitest": "^1.0.0"
    }
}